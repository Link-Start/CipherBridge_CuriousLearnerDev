# 复制为 ai.yaml 后填入你的 API Key（ai.yaml 已在 .gitignore 中，不会提交）
api_key: "your-api-key-here"
base_url: https://api.deepseek.com/v1
browser:
  headless: false
  hook_enabled: true
  mitm_port: 8080
  use_mitm_proxy: false
http_proxy: 127.0.0.1:7897
model: deepseek-chat
provider: deepseek
use_http_proxy: false
